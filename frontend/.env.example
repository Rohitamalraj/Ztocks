# ─── WalletConnect / Reown (https://cloud.reown.com) ─────────────────────────
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# ─── Sepolia Chain ────────────────────────────────────────────────────────────
NEXT_PUBLIC_CHAIN_ID=11155111
NEXT_PUBLIC_RPC_URL=https://rpc.sepolia.org

# ─── Oracle (Baby Jubjub EdDSA key for KYC credential signing) ───────────────
# Generate with: cd contracts && npx ts-node scripts/gen-oracle-key.ts
ORACLE_PRIVATE_KEY=
ORACLE_PUBKEY_AX=
ORACLE_PUBKEY_AY=

# Backend for /api/kyc/issue (Next rewrites to same origin if you use frontend API routes instead)
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001

# Optional: override defaults in lib/sepolia-defaults.json (committed Sepolia deployment)
NEXT_PUBLIC_ZK_VERIFIER_ADDRESS=
NEXT_PUBLIC_TIER_MANAGER_ADDRESS=
NEXT_PUBLIC_SYNTH_VAULT_ADDRESS=
NEXT_PUBLIC_CUSDC_ADDRESS=
NEXT_PUBLIC_USDC_ADDRESS=
NEXT_PUBLIC_CSAAPL_ADDRESS=
NEXT_PUBLIC_CSTSLA_ADDRESS=
NEXT_PUBLIC_CSNVDA_ADDRESS=
NEXT_PUBLIC_CSSPY_ADDRESS=
NEXT_PUBLIC_CSAMZN_ADDRESS=
NEXT_PUBLIC_CSMSFT_ADDRESS=
NEXT_PUBLIC_CSMETA_ADDRESS=
NEXT_PUBLIC_CSNFLX_ADDRESS=
NEXT_PUBLIC_CSAMD_ADDRESS=
