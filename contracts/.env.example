# Deployer wallet private key (with 0x prefix)
PRIVATE_KEY=0xyour_deployer_private_key_here

# Sepolia RPC
SEPOLIA_RPC_URL=https://rpc.sepolia.org

# Oracle Baby Jubjub public key (for ZK tier verification)
# Generate with: npx ts-node scripts/gen-oracle-key.ts
ORACLE_PUBKEY_AX=
ORACLE_PUBKEY_AY=

# Etherscan API key (for contract verification)
ETHERSCAN_API_KEY=

# Gas reporting
REPORT_GAS=false
